# =============================================================================
# eng-crew environment configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider — choose one: anthropic | openrouter | gemini
# -----------------------------------------------------------------------------
ENG_CREW_PROVIDER=anthropic

# Anthropic (Claude) — required when PROVIDER=anthropic
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenRouter — required when PROVIDER=openrouter
# Get your key at https://openrouter.ai/
OPENROUTER_API_KEY=

# Google Gemini — required when PROVIDER=gemini
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Model selection (per provider)
# -----------------------------------------------------------------------------
# Anthropic models: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
ENG_CREW_ARCHITECT_MODEL=claude-sonnet-4-6
ENG_CREW_CODER_MODEL=claude-sonnet-4-6
ENG_CREW_REVIEWER_MODEL=claude-sonnet-4-6

# OpenRouter model slugs (used when PROVIDER=openrouter)
# e.g. deepseek/deepseek-chat, meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=deepseek/deepseek-chat

# Gemini model (used when PROVIDER=gemini)
# e.g. gemini-1.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Budget & rate limits
# -----------------------------------------------------------------------------
# Maximum USD spend per single run (0 = unlimited)
ENG_CREW_BUDGET_USD=5.00

# Maximum tokens per LLM call
ENG_CREW_MAX_TOKENS=8192

# Maximum retries per subtask before marking it failed
ENG_CREW_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Dashboard
# -----------------------------------------------------------------------------
# Port for the web dashboard
ENG_CREW_DASHBOARD_PORT=9000

# Host to bind the dashboard server (0.0.0.0 for Docker, 127.0.0.1 for local)
ENG_CREW_DASHBOARD_HOST=127.0.0.1

# Secret key for dashboard session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
ENG_CREW_SECRET_KEY=

# -----------------------------------------------------------------------------
# Pipeline behavior
# -----------------------------------------------------------------------------
# Whether human-in-the-loop approval is required before coding begins (true|false)
ENG_CREW_REQUIRE_APPROVAL=true

# Number of parallel coder agents (1–8)
ENG_CREW_CODER_PARALLELISM=2

# Git branch prefix for ai-team runs
ENG_CREW_BRANCH_PREFIX=ai-team

# -----------------------------------------------------------------------------
# Data & storage
# -----------------------------------------------------------------------------
# Directory where run artifacts, logs, and checkpoints are stored
ENG_CREW_DATA_DIR=.eng-crew

# Maximum run history entries to retain (0 = unlimited)
ENG_CREW_MAX_RUN_HISTORY=100

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
ENG_CREW_LOG_LEVEL=INFO

# Log format: json | console
ENG_CREW_LOG_FORMAT=console
